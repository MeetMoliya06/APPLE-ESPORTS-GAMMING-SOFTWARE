# ==========================================
# NeonArena ERP - Production Environment Variables
# ==========================================

# ── Database Credentials ──
DB_USER=neonarena_admin
DB_PASSWORD=SecureDbPassword123!
DB_NAME=NeonArenaErp

# ── Redis (SignalR Backplane) ──
REDIS_PASSWORD=SecureRedisPassword123!

# ── JWT Secrets ──
# IMPORTANT: Generate new secure strings for production!
# Minimum 32 characters required by HMAC-SHA256
JWT_SECRET=supersecretkey_min_32_chars_long!!
JWT_REFRESH_SECRET=supersecretkey_refresh_min_32_chars_long!!

# ── Let's Encrypt (Certbot) ──
# Replace with your actual domain and email
DOMAIN_NAME=erp.yourdomain.com
CERTBOT_EMAIL=admin@yourdomain.com
