# ═══════════════════════════════════════════════════════════
# Gaming Café ERP — Server Environment Configuration
# ═══════════════════════════════════════════════════════════

# ── Server ──
NODE_ENV=development
PORT=4000

# ── Database (matches docker-compose.yml) ──
DATABASE_URL=postgresql://gamecafe_admin:GameCafe_Secure_2026!@localhost:5432/gamecafe_erp
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gamecafe_erp
DB_USER=gamecafe_admin
DB_PASSWORD=GameCafe_Secure_2026!
DB_POOL_MIN=2
DB_POOL_MAX=20

# ── JWT Authentication ──
JWT_SECRET=your_jwt_secret_change_in_production_64chars_min
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production_64chars_min
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── CORS ──
CORS_ORIGIN=http://localhost:5173

# ── Socket.IO ──
SOCKET_CORS_ORIGIN=http://localhost:5173

# ── Session & Operational Config (SOP Rules) ──
SESSION_TIMEOUT_MS=86400000
RESERVATION_GRACE_PERIOD_MIN=15
LONG_SESSION_ALERT_HOURS=8

# ── Logging ──
LOG_LEVEL=debug
LOG_DIR=./logs
